javascript:(function(){var t=null,i=null,run=false,c=0;var u=document.createElement("div");u.style="position:fixed;top:5px;right:5px;width:150px;background:#fff;z-index:999999;border:3px solid #007bff;padding:10px;font-family:sans-serif;color:#000";u.innerHTML="<b>Auto clicker v2, simplefied</b><div id='tx'>Pick Target</div><input type='range' id='sl' min='1' max='10000' value='50' style='width:100%'><div id='cp'>50 CPS</div><button id='go' style='width:100%'>START</button>";document.body.appendChild(u);var sl=document.getElementById("sl"),cp=document.getElementById("cp"),go=document.getElementById("go"),tx=document.getElementById("tx");sl.oninput=function(){cp.innerText=sl.value+" CPS";};go.onclick=function(){run=!run;go.innerText=run?"STOP":"START";if(i)clearInterval(i);if(run&&t)i=setInterval(function(){for(var j=0;j<Math.ceil(sl.value/20);j++){t.click();c++;}tx.innerText=c+' clicks'},50);};document.addEventListener("click",function(e){if(!t){e.preventDefault();t=e.target;tx.innerText="Ready!";}},{once:true});})();
