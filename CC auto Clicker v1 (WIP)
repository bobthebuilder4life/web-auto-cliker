javascript:(function(){    var ui = document.createElement("div");    var isBypass = false;    ui.style = "position:fixed;top:20px;right:20px;width:180px;padding:15px;background:rgba(255,255,255,0.95);backdrop-filter:blur(10px);color:#333;font-family:Sans-Serif;z-index:10000;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,0.15);border:1px solid rgba(255,255,255,0.3);transition:all 0.3s ease;";    ui.innerHTML = "<div style='font-size:11px;font-weight:600;letter-spacing:1px;color:#888;margin-bottom:8px;'> CC Auto Clicker v1</div>" +                   "<div id='ac-stat' style='font-size:20px;font-weight:300;'>Choose Where To Click</div>" +                   "<div id='ac-cps' style='font-size:12px;color:#007bff;margin-bottom:10px;font-weight:500;'>0 CPS</div>" +                    "<button id='ac-bypass' style='width:100%;padding:5px;margin-bottom:10px;border-radius:6px;border:1px solid #ddd;background:#fff;cursor:pointer;font-size:10px;font-weight:bold;'>BYPASS: OFF</button>" +                   "<div style='height:4px;width:100%;background:#eee;border-radius:2px;overflow:hidden;'><div id='ac-prog' style='height:100%;width:0%;background:#007bff;transition:width 0.1s;'></div></div>";        var s = document.createElement("style");    s.innerHTML = ".ac-selecting * {cursor:crosshair !important;} .ac-target{outline: 2px solid #007bff !important; outline-offset: 4px !important;}";    document.head.appendChild(s);    document.body.appendChild(ui);    document.documentElement.classList.add("ac-selecting");    ui.querySelector('#ac-bypass').onclick = function(e) {        e.stopPropagation();        isBypass = !isBypass;        this.style.background = isBypass ? "#007bff" : "#fff";        this.style.color = isBypass ? "#fff" : "#000";        this.innerText = "BYPASS: " + (isBypass ? "ON" : "OFF");    };    function start(e) {        if(e.target.id === 'ac-bypass') return;        e.preventDefault(); e.stopImmediatePropagation();        var t = e.target;        document.documentElement.classList.remove("ac-selecting");        t.classList.add("ac-target");        document.removeEventListener("click", start, true);                var c = 0, lastC = 0;        var interval = setInterval(function() {            if (isBypass && typeof Game !== 'undefined' && Game.ClickCookie) {                /* Bypass-läge: Pratar direkt med Cookie Clickers motor */                Game.ClickCookie();            } else {                /* Vanligt läge för andra sidor */                t.click();            }            c++;            if(c % 10 === 0) {                document.getElementById('ac-stat').innerText = c + " click";                document.getElementById('ac-prog').style.width = (c % 100) + "%";            }        }, 1);        var cpsInterval = setInterval(function() {            document.getElementById('ac-cps').innerText = (c - lastC) + " CPS";            lastC = c;        }, 1000);        window.addEventListener('keydown', function(ev) {            if (ev.key.toLowerCase() === 's') {                clearInterval(interval); clearInterval(cpsInterval);                t.classList.remove("ac-target");                ui.style.opacity = "0";                setTimeout(function() { ui.remove(); s.remove(); }, 300);            }        }, { once: true });    }    document.addEventListener("click", start, true);})();
