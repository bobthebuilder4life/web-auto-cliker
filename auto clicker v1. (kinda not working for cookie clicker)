javascript:(function(){    var ui = document.createElement("div");    ui.style = "position:fixed;top:20px;right:20px;width:180px;padding:15px;background:rgba(255,255,255,0.9);backdrop-filter:blur(10px);color:#333;font-family:Sans-Serif;z-index:10000;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,0.15);border:1px solid rgba(255,255,255,0.3);transition:all 0.3s ease;";    ui.innerHTML = "<div style='font-size:11px;font-weight:600;letter-spacing:1px;color:#888;margin-bottom:8px;'>AUTOCLICKER</div>" +                   "<div id='ac-stat' style='font-size:20px;font-weight:300;'>Välj mål...</div>" +                   "<div id='ac-cps' style='font-size:12px;color:#007bff;margin-bottom:10px;font-weight:500;'>0 CPS</div>" +                    "<div style='height:4px;width:100%;background:#eee;border-radius:2px;overflow:hidden;'><div id='ac-prog' style='height:100%;width:0%;background:#007bff;transition:width 0.1s;'></div></div>";        var s = document.createElement("style");    s.innerHTML = ".ac-selecting * {cursor:crosshair !important;} .ac-target{outline: 2px solid #007bff !important; outline-offset: 4px !important;}";    document.head.appendChild(s);    document.body.appendChild(ui);    document.documentElement.classList.add("ac-selecting");    function start(e) {        e.preventDefault();        e.stopImmediatePropagation();        var t = e.target;        document.documentElement.classList.remove("ac-selecting");        t.classList.add("ac-target");        document.removeEventListener("click", start, true);        ui.style.borderLeft = "4px solid #007bff";                var c = 0;        var lastC = 0;        var interval = setInterval(function() {            t.click();            c++;            if(c % 5 === 0) {                document.getElementById('ac-stat').innerText = c + " klick";                document.getElementById('ac-prog').style.width = (c % 100) + "%";            }        }, 1);        /* CPS-logik: mäter skillnaden varje sekund */        var cpsInterval = setInterval(function() {            var cps = c - lastC;            document.getElementById('ac-cps').innerText = cps + " CPS";            lastC = c;        }, 1000);        window.addEventListener('keydown', function(ev) {            if (ev.key.toLowerCase() === 's') {                clearInterval(interval);                clearInterval(cpsInterval);                t.classList.remove("ac-target");                ui.style.opacity = "0";                ui.style.transform = "translateY(-20px)";                setTimeout(function() { ui.remove(); s.remove(); }, 300);            }        }, { once: true });    }    document.addEventListener("click", start, true);})();
